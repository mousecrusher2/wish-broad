{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "whip-worker",
  "main": "worker/index.ts",
  "compatibility_date": "2025-04-27",
  // "compatibility_flags": [
  //   "nodejs_compat"
  // ],
  // "vars": {
  //   "AUTHORIZED_GUILD_ID": "your-discord-guild-id-here",
  //   "ENVIRONMENT": "development"
  // },
  "vars": {
    "ENVIRONMENT": "production",
  },
  "d1_databases": [
    {
      "binding": "LIVE_DB",
      "database_name": "broad-db",
      "database_id": "2d57ee62-6f7c-490a-974f-5df3b194a860",
    },
  ],
  "assets": {
    "not_found_handling": "none",
    "run_worker_first": false,
    "directory": "./dist",
  },
  "observability": {
    "logs": {
      "enabled": true,
      "head_sampling_rate": 1,
    },
  },
}
